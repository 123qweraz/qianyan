#!/bin/bash
# Pre-removal script for shian-ime

set -e

echo "Removing shian-ime..."

# Kill running instance if any
pkill -f shian-ime 2>/dev/null || true

# Remove autostart entry
rm -f /etc/xdg/autostart/shian-ime.desktop 2>/dev/null || true
rm -f ~/.config/autostart/shian-ime.desktop 2>/dev/null || true

echo "shian-ime removal completed."
