{
  "english": {
    "name": "English Default Layout",
    "mappings": {
      ";": {
        "tap": ";",
        "shift": ":",
        "description": "英文分号"
      },
      ",": {
        "tap": ",",
        "shift": "<",
        "description": "英文逗号"
      },
      ".": {
        "tap": ".",
        "shift": ">",
        "description": "英文句号"
      }
    }
  },
  "stroke": {
    "name": "笔画默认布局",
    "mappings": {}
  },
  "chinese": {
    "name": "中文默认布局",
    "mappings": {
      ".": {
        "tap": "。",
        "shift": "》",
        "double_tap": "...",
        "long_press": "·",
        "description": "中文句号"
      },
      ",": {
        "tap": "，",
        "shift": "《",
        "long_press": "、",
        "description": "中文逗号"
      },
      ";": {
        "tap": "；",
        "shift": "：",
        "double_tap": ";",
        "long_press": "……",
        "description": "中文分号"
      },
      "?": {
        "tap": "？",
        "shift": "?",
        "description": "中文问号"
      },
      "!": {
        "tap": "！",
        "shift": "!",
        "description": "中文叹号"
      }
    }
  },
  "japanese": {
    "name": "日本語デフォルト配列",
    "mappings": {
      "/": {
        "tap": "・",
        "shift": "?",
        "description": "日文中点"
      },
      "[": {
        "tap": "「",
        "shift": "{",
        "description": "日文左引号"
      },
      ".": {
        "tap": "。",
        "shift": ">",
        "long_press": "・",
        "description": "日文句号"
      },
      "]": {
        "tap": "」",
        "shift": "}",
        "description": "日文右引号"
      },
      ",": {
        "tap": "、",
        "shift": "<",
        "description": "日文顿号"
      }
    }
  }
}