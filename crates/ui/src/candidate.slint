export struct CandidateData {
    text: string,
    label: string,
    english_aux: string,
    stroke_aux: string,
    is_fuzzy: bool,
}

component CandidateItem inherits Rectangle {
    in property <string> text;
    in property <string> label;
    in property <string> english_aux;
    in property <string> stroke_aux;
    in property <bool> selected;
    in property <bool> is_horizontal;
    
    in property <color> accent_color;
    in property <color> text_color;
    in property <color> highlight_text_color;
    in property <color> aux_text_color;
    in property <color> aux_highlight_color;
    in property <bool> is_fuzzy;
    in property <color> fuzzy_text_color: #a0a0a0;
    
    in property <length> font_size: 18px;
    in property <string> font_family: "";
    in property <int> font_weight: 400;

    background: selected ? accent_color : transparent;
    border-radius: 4px;
    
    layout := HorizontalLayout {
        padding-left: 8px; padding-right: 8px; 
        padding-top: 6px; padding-bottom: 6px;
        spacing: 6px;
        alignment: start;
        
        Text { 
            text: label; 
            color: selected ? highlight_text_color : aux_text_color; 
            vertical-alignment: center; 
            font-size: font_size * 0.8;
            font-family: font_family;
            font-weight: font_weight;
        }
        Text {
            text: text;
            color: selected ? highlight_text_color : (is_fuzzy ? fuzzy_text_color : text_color);
            vertical-alignment: center;
            font-size: font_size;
            font-family: font_family != "" ? font_family : "Segoe UI Emoji, Microsoft YaHei, Segoe UI, system-ui";
            font-weight: is_fuzzy ? 400 : font_weight;
        }
        
        // 辅助码/音调内容由引擎根据 display_mode 生成，不为空即显示
        if english_aux != "" : Text {
            text: english_aux;
            color: selected ? highlight_text_color : text_color;
            font-size: font_size;
            font-family: font_family;
            vertical-alignment: center;
        }
    }
}

export component CandidateWindow inherits Window {
    title: "RustImeCandidateWindow";
    in property <string> pinyin;
    in property <[CandidateData]> candidates;
    in property <int> selected_index: 0;
    in property <int> current_page: 0;
    in property <int> total_pages: 0;
    in property <bool> is_visible: false;
    in property <bool> is_horizontal: true;
    
    in property <length> pinyin_font_size: 14px;
    in property <string> pinyin_font_family: "";
    in property <int> pinyin_font_weight: 400;
    in property <length> candidate_font_size: 18px;
    in property <string> candidate_font_family: "";
    in property <int> candidate_font_weight: 400;
    
    in property <length> win_border_radius: 6px;
    in property <color> accent_color: #0969da;
    in property <color> bg_color: #ffffff;
    in property <color> border_color: #dcdde1;
    in property <color> text_color: #2c3e50;
    in property <color> highlight_text_color: #ffffff;
    in property <color> aux_text_color: #95a5a6;
    in property <color> aux_highlight_color: #dcdde1;

    no-frame: true;
    background: transparent;
    always-on-top: true;

    // Width adapts to content, minimum 200px for readability
    width: max(main_rect.preferred-width, 200px);
    // Height adapts to content, minimum 100px for readability
    height: max(main_rect.preferred-height, 100px);

    main_rect := Rectangle {
        visible: is_visible;
        background: bg_color;
        border-radius: win_border_radius;
        border-width: 1px;
        border-color: border_color;
        
        drop-shadow-blur: 12px;
        drop-shadow-color: rgba(0, 0, 0, 0.25);
        drop-shadow-offset-y: 4px;

        VerticalLayout {
            padding: 10px;
            spacing: 6px;
            alignment: start;

            if pinyin != "" : HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: 8px;
                Text {
                    text: pinyin;
                    color: accent_color;
                    font-size: pinyin_font_size;
                    font-family: pinyin_font_family;
                    font-weight: 600;
                }
                Rectangle { }
                Text {
                    text: total_pages > 0 ? (current_page + 1) + "/" + total_pages : "";
                    color: aux_text_color;
                    font-size: pinyin_font_size * 0.8;
                    font-family: pinyin_font_family;
                    font-weight: 400;
                    vertical-alignment: center;
                }
            }

            if is_horizontal : HorizontalLayout {
                spacing: 4px;
                for cand[i] in candidates : CandidateItem {
                    text: cand.text;
                    label: cand.label;
                    english_aux: cand.english_aux;
                    stroke_aux: cand.stroke_aux;
                    selected: i == selected_index;
                    is_horizontal: true;
                    is_fuzzy: cand.is_fuzzy;
                    accent_color: accent_color;
                    text_color: text_color;
                    highlight_text_color: highlight_text_color;
                    aux_text_color: aux_text_color;
                    aux_highlight_color: aux_highlight_color;
                    font_size: candidate_font_size;
                    font_family: candidate_font_family;
                    font_weight: candidate_font_weight;
                }
            }

            if !is_horizontal : VerticalLayout {
                spacing: 2px;
                for cand[i] in candidates : CandidateItem {
                    text: cand.text;
                    label: cand.label;
                    english_aux: cand.english_aux;
                    stroke_aux: cand.stroke_aux;
                    selected: i == selected_index;
                    is_horizontal: false;
                    is_fuzzy: cand.is_fuzzy;
                    accent_color: accent_color;
                    text_color: text_color;
                    highlight_text_color: highlight_text_color;
                    aux_text_color: aux_text_color;
                    aux_highlight_color: aux_highlight_color;
                    font_size: candidate_font_size;
                    font_family: candidate_font_family;
                    font_weight: candidate_font_weight;
                }
            }
        }
    }
}
